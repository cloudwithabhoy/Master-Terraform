        </mxCell>

        <mxCell id="n_alb" value="Application Load Balancer (ALB)&lt;br&gt;HTTP :80 — spans both public subnets" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="560" y="320" width="340" height="60" as="geometry" />
        </mxCell>

        <!-- ============ Public Subnet AZ-a ============ -->
