          <mxGeometry x="340" y="460" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n_alb_a_note" value="ALB ENI (AZ-a)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;dashed=1;fontSize=11;" vertex="1" parent="1">
