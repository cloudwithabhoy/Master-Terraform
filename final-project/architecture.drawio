<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram name="Final Project - AWS Architecture" id="final-project-architecture">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============ Outside AWS: users ============ -->
        <mxCell id="n_user" value="End User&lt;br&gt;(browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="260" y="20" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n_operator" value="Operator&lt;br&gt;(SSH, allow-listed IP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="1200" y="20" width="200" height="50" as="geometry" />
