        </mxCell>

        <!-- ============ Legend ============ -->
        <mxCell id="n_legend" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br&gt;Blue = compute (EC2)&lt;br&gt;Green = data / networking gateway&lt;br&gt;Orange = load balancing / NAT&lt;br&gt;Red = account-level AWS services&lt;br&gt;Dashed = conditional (prod-only) or logical/via-NAT path" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="940" width="420" height="140" as="geometry" />
        </mxCell>

        <!-- ============ Edges ============ -->
