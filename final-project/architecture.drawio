          <mxGeometry x="40" y="210" width="1420" height="710" as="geometry" />
        </mxCell>

        <mxCell id="n_igw" value="Internet Gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
