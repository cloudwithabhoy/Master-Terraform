<mxfile host="drawio-plugin" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36" modified="2026-07-22T06:16:02.910Z" version="22.1.22" etag="YgOVR9eJ9I3cq1hxV2WV" type="embed">
  <diagram name="Final Project - CI-CD Branch Promotion" id="final-project-cicd">
    <mxGraphModel dx="394" dy="752" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1820" pageHeight="1019" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n_bootstrap" value="&lt;b&gt;Precondition — the one exception to &amp;quot;everything through the pipeline&amp;quot;:&lt;/b&gt;&lt;br&gt;bootstrap/dev, bootstrap/qa, bootstrap/prod each create that environment&#39;s S3 bucket + DynamoDB table (Day 8 Topic 1 §4 pattern) — local-state, one-time, run manually &lt;i&gt;before&lt;/i&gt; that environment&#39;s stage below can ever run. Nothing else in this flow is ever run from a laptop." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="60" y="20" width="1200" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n_stage1" value="Stage 1 — feature → dev  (AUTO-APPLY, no approval gate)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;dashed=1;verticalAlign=top;align=left;fontStyle=1;fontSize=14;spacingLeft=10;spacingTop=6;" parent="1" vertex="1">
          <mxGeometry x="40" y="130" width="1200" height="200" as="geometry" />
        </mxCell>
        <mxCell id="box1_pr" value="PR opened&lt;br&gt;target: dev branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="70" y="190" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box1_plan" value="terraform-plan.yml&lt;br&gt;plans environments/dev&lt;br&gt;posts PR comment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="300" y="185" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="box1_review" value="Human review&lt;br&gt;(reads the plan)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="540" y="190" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box1_merge" value="Merge → dev branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="760" y="190" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box1_apply" value="terraform-apply.yml&lt;br&gt;applies environments/dev&lt;br&gt;AUTOMATIC — no gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="980" y="185" width="230" height="70" as="geometry" />
        </mxCell>
        <mxCell id="n_stage2" value="Stage 2 — dev → qa promotion  (approval-gated)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;dashed=1;verticalAlign=top;align=left;fontStyle=1;fontSize=14;spacingLeft=10;spacingTop=6;" parent="1" vertex="1">
          <mxGeometry x="40" y="370" width="1200" height="220" as="geometry" />
        </mxCell>
        <mxCell id="box2_pr" value="Promotion PR&lt;br&gt;target: qa branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="70" y="430" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box2_plan" value="terraform-plan.yml&lt;br&gt;plans environments/qa&lt;br&gt;posts PR comment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="300" y="425" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="box2_review" value="Human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="540" y="430" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box2_merge" value="Merge → qa branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="760" y="430" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box2_apply" value="terraform-apply.yml&lt;br&gt;WAITS: GitHub Environment&lt;br&gt;&#39;qa&#39; reviewer approval&lt;br&gt;then applies environments/qa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="980" y="420" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n_stage3" value="Stage 3 — qa → main promotion  (main = prod branch, approval-gated)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#232F3E;dashed=1;verticalAlign=top;align=left;fontStyle=1;fontSize=14;spacingLeft=10;spacingTop=6;" parent="1" vertex="1">
          <mxGeometry x="40" y="630" width="1200" height="220" as="geometry" />
        </mxCell>
        <mxCell id="box3_pr" value="Promotion PR&lt;br&gt;target: main branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="70" y="690" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box3_plan" value="terraform-plan.yml&lt;br&gt;plans environments/prod&lt;br&gt;posts PR comment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
          <mxGeometry x="300" y="685" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="box3_review" value="Human review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="540" y="690" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box3_merge" value="Merge → main branch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="760" y="690" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="box3_apply" value="terraform-apply.yml&lt;br&gt;WAITS: GitHub Environment&lt;br&gt;&#39;prod&#39; reviewer approval&lt;br&gt;then applies environments/prod" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="980" y="680" width="230" height="90" as="geometry" />
        </mxCell>
        <mxCell id="n_done" value="Done — dev, qa, and prod&lt;br&gt;all now at this commit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="980" y="910" width="230" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n_branchmap" value="&lt;b&gt;Branch → folder mapping&lt;/b&gt;&lt;br&gt;dev branch → environments/dev&lt;br&gt;qa branch → environments/qa&lt;br&gt;main branch → environments/prod&lt;br&gt;&lt;br&gt;All environments/* folders exist on every branch — both workflows map branch name → folder, not just &#39;any push&#39;." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1300" y="185" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n_discipline" value="&lt;b&gt;Discipline this model requires&lt;/b&gt;&lt;br&gt;qa and main only ever move forward via a promotion PR from the branch below (dev→qa, qa→main) — never a direct commit or a PR from elsewhere. Skipping this is exactly how branch-per-environment setups drift out of sync." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1300" y="425" width="440" height="150" as="geometry" />
        </mxCell>
        <mxCell id="n_rulerecap" value="&lt;b&gt;Rule recap&lt;/b&gt;&lt;br&gt;Every apply, every environment, happens through the pipeline — dev included. The only exception is the bootstrap/ configs above: local, one-time, before any pipeline can run." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontSize=12;" parent="1" vertex="1">
          <mxGeometry x="1300" y="680" width="440" height="150" as="geometry" />
        </mxCell>
